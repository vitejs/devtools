{
  "name": "takubox",
  "type": "module",
  "version": "0.0.0",
  "description": "A general devtools foundation — RPC layer, hosts, adapters (CLI/build/SPA/vite/kit/embedded).",
  "author": "VoidZero Inc.",
  "license": "MIT",
  "homepage": "https://github.com/vitejs/devtools#readme",
  "repository": {
    "directory": "packages/takubox",
    "type": "git",
    "url": "git+https://github.com/vitejs/devtools.git"
  },
  "bugs": "https://github.com/vitejs/devtools/issues",
  "keywords": [
    "devtools",
    "rpc",
    "toolbox"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./rpc": "./dist/rpc/index.mjs",
    "./rpc/client": "./dist/rpc/client.mjs",
    "./rpc/presets": "./dist/rpc/presets/index.mjs",
    "./rpc/presets/ws/client": "./dist/rpc/presets/ws/client.mjs",
    "./rpc/presets/ws/server": "./dist/rpc/presets/ws/server.mjs",
    "./rpc/server": "./dist/rpc/server.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "watch": "tsdown --watch",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "birpc": "catalog:deps",
    "logs-sdk": "catalog:deps",
    "ohash": "catalog:deps",
    "p-limit": "catalog:deps",
    "structured-clone-es": "catalog:deps",
    "valibot": "catalog:deps",
    "ws": "catalog:deps"
  },
  "devDependencies": {
    "tsdown": "catalog:build"
  }
}
