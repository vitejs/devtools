{
  "name": "takubox",
  "type": "module",
  "version": "0.0.0",
  "description": "A general devtools foundation — RPC layer, hosts, adapters (CLI/build/SPA/vite/kit/embedded).",
  "author": "VoidZero Inc.",
  "license": "MIT",
  "homepage": "https://github.com/vitejs/devtools#readme",
  "repository": {
    "directory": "packages/takubox",
    "type": "git",
    "url": "git+https://github.com/vitejs/devtools.git"
  },
  "bugs": "https://github.com/vitejs/devtools/issues",
  "keywords": [
    "devtools",
    "rpc",
    "toolbox"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./constants": "./dist/constants.mjs",
    "./node": "./dist/node/index.mjs",
    "./rpc": "./dist/rpc/index.mjs",
    "./rpc/client": "./dist/rpc/client.mjs",
    "./rpc/presets": "./dist/rpc/presets/index.mjs",
    "./rpc/presets/ws/client": "./dist/rpc/presets/ws/client.mjs",
    "./rpc/presets/ws/server": "./dist/rpc/presets/ws/server.mjs",
    "./rpc/server": "./dist/rpc/server.mjs",
    "./types": "./dist/types/index.mjs",
    "./utils/events": "./dist/utils/events.mjs",
    "./utils/human-id": "./dist/utils/human-id.mjs",
    "./utils/nanoid": "./dist/utils/nanoid.mjs",
    "./utils/promise": "./dist/utils/promise.mjs",
    "./utils/shared-state": "./dist/utils/shared-state.mjs",
    "./utils/state": "./dist/utils/state.mjs",
    "./utils/when": "./dist/utils/when.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "watch": "tsdown --watch",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "birpc": "catalog:deps",
    "logs-sdk": "catalog:deps",
    "ohash": "catalog:deps",
    "p-limit": "catalog:deps",
    "structured-clone-es": "catalog:deps",
    "valibot": "catalog:deps",
    "ws": "catalog:deps"
  },
  "devDependencies": {
    "tsdown": "catalog:build"
  },
  "inlinedDependencies": {
    "acorn": "8.16.0",
    "ansis": "4.2.0",
    "human-id": "4.1.3",
    "immer": "11.1.4",
    "mlly": "1.8.2",
    "obug": "2.1.1",
    "pathe": "2.0.3",
    "perfect-debounce": "2.1.0",
    "tinyexec": "1.1.1"
  }
}
