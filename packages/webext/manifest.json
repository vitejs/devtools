{
  "action": {
    "default_title": "Vite DevTools",
    "default_icon": {
      "16": "icons/16-inactive.png",
      "48": "icons/48-inactive.png",
      "128": "icons/128-inactive.png"
    }
  },
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "description": "DevTools browser extension for Vite",
  "devtools_page": "app/background/background.html",
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "manifest_version": 3,
  "name": "Vite DevTools",
  "permissions": [
    "scripting"
  ],
  "version": "0.0.0",
  "version_name": "0.0.0",
  "web_accessible_resources": [
    {
      "extension_ids": [],
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "dist/*",
        "app/background/*"
      ]
    }
  ]
}
