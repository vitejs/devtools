{
  "name": "devframe",
  "type": "module",
  "version": "0.0.0",
  "description": "Framework for building generic DevTools",
  "author": "Anthony Fu <anthonyfu117@hotmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/vitejs/devtools#readme",
  "repository": {
    "directory": "packages/devframe",
    "type": "git",
    "url": "git+https://github.com/vitejs/devtools.git"
  },
  "bugs": "https://github.com/vitejs/devtools/issues",
  "keywords": [
    "devtools",
    "rpc",
    "toolbox"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./build": "./dist/build.mjs",
    "./cli": "./dist/cli.mjs",
    "./client": "./dist/client.mjs",
    "./constants": "./dist/constants.mjs",
    "./embedded": "./dist/embedded.mjs",
    "./kit": "./dist/kit.mjs",
    "./node": "./dist/node/index.mjs",
    "./rpc": "./dist/rpc/index.mjs",
    "./rpc/client": "./dist/rpc/client.mjs",
    "./rpc/server": "./dist/rpc/server.mjs",
    "./rpc/transports/ws-client": "./dist/rpc/transports/ws-client.mjs",
    "./rpc/transports/ws-server": "./dist/rpc/transports/ws-server.mjs",
    "./spa": "./dist/spa.mjs",
    "./types": "./dist/types/index.mjs",
    "./utils/events": "./dist/utils/events.mjs",
    "./utils/human-id": "./dist/utils/human-id.mjs",
    "./utils/nanoid": "./dist/utils/nanoid.mjs",
    "./utils/promise": "./dist/utils/promise.mjs",
    "./utils/shared-state": "./dist/utils/shared-state.mjs",
    "./utils/state": "./dist/utils/state.mjs",
    "./utils/when": "./dist/utils/when.mjs",
    "./vite": "./dist/vite.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "watch": "tsdown --watch",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "ansis": "catalog:deps",
    "birpc": "catalog:deps",
    "cac": "catalog:deps",
    "get-port-please": "catalog:deps",
    "h3": "catalog:deps",
    "logs-sdk": "catalog:deps",
    "ohash": "catalog:deps",
    "p-limit": "catalog:deps",
    "pathe": "catalog:deps",
    "sirv": "catalog:deps",
    "structured-clone-es": "catalog:deps",
    "valibot": "catalog:deps",
    "ws": "catalog:deps"
  },
  "devDependencies": {
    "tsdown": "catalog:build"
  },
  "inlinedDependencies": {
    "@jridgewell/trace-mapping": "0.3.31",
    "@oxc-project/types": "0.126.0",
    "@rolldown/pluginutils": "1.0.0-rc.16",
    "acorn": "8.16.0",
    "esbuild": "0.28.0",
    "human-id": "4.1.3",
    "immer": "11.1.4",
    "mlly": "1.8.2",
    "obug": "2.1.1",
    "perfect-debounce": "2.1.0",
    "postcss": "8.5.10",
    "rolldown": "1.0.0-rc.16",
    "terser": "5.44.1",
    "tinyexec": "1.1.1",
    "ua-parser-modern": "0.1.1",
    "vite": "8.0.9"
  }
}
